# Match-day board environment configuration
#
# When BOTH variables below are set, the app connects to Supabase (production mode).
# When EITHER is missing/empty, the app automatically runs in local DEMO mode
# (browser localStorage, seeded admin + game, no server). Demo mode is NOT secure
# and must never be treated as production.
#
# Copy this file to `.env` and fill in your project values.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
